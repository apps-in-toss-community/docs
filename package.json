{
  "name": "@ait-co/docs",
  "version": "0.0.0",
  "description": "Community-maintained, cleaner and friendlier guides and references for Apps in Toss mini-app development",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "docusaurus start",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@mdx-js/react": "3.1.0",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@types/react": "18.3.12",
    "typescript": "5.6.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "keywords": [
    "apps-in-toss",
    "toss",
    "mini-app",
    "docs"
  ],
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "webpack": "5.105.0"
    }
  },
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/apps-in-toss-community/docs"
  },
  "bugs": {
    "url": "https://github.com/apps-in-toss-community/docs/issues"
  }
}
